extension/out/

# Autonomous driver state
.specify/state/sessions/
.specify/state/logs/

# Gofer state files (auto-generated, should not be committed)
.specify/memory/dependency-graph.json
.specify/specs/*/.branch-info.json

# Gofer hooks runtime state (ephemeral, session-specific)
.specify/hooks/
