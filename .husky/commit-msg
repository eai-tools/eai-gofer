#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Check commit message format (conventional commits)
commit_regex='^(feat|fix|docs|style|refactor|test|chore|ci|build|perf|revert)(\(.+\))?: .{1,50}'

if ! grep -qE "$commit_regex" "$1"; then
    echo "❌ Invalid commit message format!"
    echo ""
    echo "Commit message should follow conventional commits format:"
    echo "  <type>[optional scope]: <description>"
    echo ""
    echo "Examples:"
    echo "  feat: add new authentication system"
    echo "  fix(api): resolve timeout issue in user endpoint"
    echo "  docs: update installation guide"
    echo "  test: add unit tests for validation service"
    echo ""
    echo "Valid types: feat, fix, docs, style, refactor, test, chore, ci, build, perf, revert"
    exit 1
fi