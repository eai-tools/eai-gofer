{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Specification Schema",
  "description": "Schema for spec-driven development specifications",
  "type": "object",
  "required": ["id", "title", "description", "tasks", "acceptanceCriteria"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this spec"
    },
    "title": {
      "type": "string",
      "description": "Title of the feature/requirement"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of what needs to be built"
    },
    "tasks": {
      "type": "array",
      "description": "Breakdown of tasks to implement this spec",
      "items": {
        "type": "object",
        "required": ["id", "description", "dependencies"],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "testing", "completed", "failed"]
          },
          "deliveryPrompt": {
            "type": "string",
            "description": "The prompt to send to Claude Code to deliver this task"
          }
        }
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "description": "Criteria that must be met for this spec to be complete",
      "items": {
        "type": "object",
        "required": ["id", "description", "testType"],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "testType": {
            "type": "string",
            "enum": ["playwright", "unit", "integration", "manual"]
          },
          "testPath": {
            "type": "string",
            "description": "Path to the test file"
          }
        }
      }
    },
    "qaRules": {
      "type": "array",
      "description": "Rules for answering questions based on spec",
      "items": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string",
            "description": "Question pattern (regex supported)"
          },
          "answer": {
            "type": "string",
            "description": "Answer from spec"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        }
      }
    }
  }
}
