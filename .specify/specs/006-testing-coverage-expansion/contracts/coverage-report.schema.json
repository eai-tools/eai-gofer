{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://specgofer.com/schemas/coverage-report.schema.json",
  "title": "Code Coverage Report",
  "description": "Code coverage metrics for SpecGofer test execution",
  "type": "object",
  "required": ["reportId", "timestamp", "branch", "commit", "lines", "branches", "functions", "statements", "thresholds"],
  "properties": {
    "reportId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this coverage report"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when coverage was collected"
    },
    "branch": {
      "type": "string",
      "minLength": 1,
      "description": "Git branch name"
    },
    "commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$",
      "description": "Git commit SHA (short or full)"
    },
    "lines": {
      "$ref": "#/definitions/coverageMetric",
      "description": "Line coverage metrics"
    },
    "branches": {
      "$ref": "#/definitions/coverageMetric",
      "description": "Branch coverage metrics"
    },
    "functions": {
      "$ref": "#/definitions/coverageMetric",
      "description": "Function coverage metrics"
    },
    "statements": {
      "$ref": "#/definitions/coverageMetric",
      "description": "Statement coverage metrics"
    },
    "perFileMetrics": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/fileCoverage"
      },
      "description": "Per-file coverage breakdown"
    },
    "thresholds": {
      "type": "object",
      "required": ["lines", "branches", "functions", "statements", "met"],
      "properties": {
        "lines": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Line coverage threshold (e.g., 85)"
        },
        "branches": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Branch coverage threshold"
        },
        "functions": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Function coverage threshold"
        },
        "statements": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Statement coverage threshold"
        },
        "met": {
          "type": "boolean",
          "description": "True if all thresholds were met"
        },
        "perFile": {
          "type": "object",
          "patternProperties": {
            "^.*\\.ts$": {
              "$ref": "#/definitions/fileThreshold"
            }
          },
          "description": "Per-file thresholds for critical paths"
        }
      },
      "description": "Coverage threshold configuration and status"
    }
  },
  "definitions": {
    "coverageMetric": {
      "type": "object",
      "required": ["total", "covered", "percentage"],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of items (lines, branches, functions, or statements)"
        },
        "covered": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of covered items"
        },
        "percentage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Coverage percentage (covered/total * 100)"
        }
      }
    },
    "fileCoverage": {
      "type": "object",
      "required": ["filePath", "lines", "branches", "functions", "statements"],
      "properties": {
        "filePath": {
          "type": "string",
          "minLength": 1,
          "description": "Relative path to source file from repository root"
        },
        "lines": {
          "$ref": "#/definitions/coverageMetric"
        },
        "branches": {
          "$ref": "#/definitions/coverageMetric"
        },
        "functions": {
          "$ref": "#/definitions/coverageMetric"
        },
        "statements": {
          "$ref": "#/definitions/coverageMetric"
        },
        "uncoveredLines": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          },
          "description": "Line numbers that are not covered by tests"
        },
        "uncoveredBranches": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "line": {
                "type": "integer",
                "minimum": 1
              },
              "branch": {
                "type": "string",
                "description": "Branch identifier (e.g., 'if', 'else')"
              }
            }
          },
          "description": "Branches not covered by tests"
        }
      }
    },
    "fileThreshold": {
      "type": "object",
      "properties": {
        "lines": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "branches": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "functions": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "statements": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      },
      "description": "Coverage thresholds for a specific file"
    }
  }
}
