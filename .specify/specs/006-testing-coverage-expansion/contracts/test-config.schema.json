{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://specgofer.com/schemas/test-config.schema.json",
  "title": "Test Configuration",
  "description": "Configuration for SpecGofer test execution including VSCode test CLI, Vitest, and Playwright settings",
  "type": "object",
  "properties": {
    "vscodeTest": {
      "type": "object",
      "description": "Configuration for @vscode/test-cli",
      "properties": {
        "version": {
          "type": "string",
          "enum": ["stable", "insiders"],
          "description": "VSCode version to test against"
        },
        "extensionDevelopmentPath": {
          "type": "string",
          "description": "Path to extension source (relative to repo root)"
        },
        "extensionTestsPath": {
          "type": "string",
          "description": "Path to test runner script"
        },
        "launchArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "VSCode launch arguments (e.g., ['--disable-extensions', './test-workspace'])"
        },
        "timeout": {
          "type": "integer",
          "minimum": 1000,
          "default": 60000,
          "description": "Test timeout in milliseconds (default: 60000ms for VSCode extension tests)"
        }
      }
    },
    "vitest": {
      "type": "object",
      "description": "Vitest configuration for unit and integration tests",
      "properties": {
        "globals": {
          "type": "boolean",
          "description": "Enable global test APIs (describe, it, expect)"
        },
        "retry": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5,
          "description": "Number of retries for failed tests (0-5)"
        },
        "testTimeout": {
          "type": "integer",
          "minimum": 1000,
          "default": 5000,
          "description": "Default test timeout in milliseconds (default: 5000ms for unit tests, 30000ms for integration)"
        },
        "coverage": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "enum": ["v8", "istanbul"],
              "description": "Coverage provider (v8 recommended)"
            },
            "reporter": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["text", "json", "html", "lcov"]
              },
              "description": "Coverage reporters to use"
            },
            "lines": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "default": 85,
              "description": "Minimum line coverage percentage (default: 85% aggregate, 80% per-file when perFile=true, 90% for critical paths)"
            },
            "branches": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "default": 85,
              "description": "Minimum branch coverage percentage (default: 85% aggregate, 80% per-file when perFile=true, 90% for critical paths)"
            },
            "functions": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "default": 85,
              "description": "Minimum function coverage percentage (default: 85% aggregate, 80% per-file when perFile=true, 90% for critical paths)"
            },
            "statements": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "default": 85,
              "description": "Minimum statement coverage percentage (default: 85% aggregate, 80% per-file when perFile=true, 90% for critical paths)"
            },
            "exclude": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Patterns to exclude from coverage (e.g., ['tests/**', 'dist/**'])"
            },
            "perFile": {
              "type": "boolean",
              "default": true,
              "description": "Enable per-file threshold checking (default: true, enforces 80% per-file minimum)"
            }
          }
        }
      }
    },
    "playwright": {
      "type": "object",
      "description": "Playwright configuration for E2E tests",
      "properties": {
        "testDir": {
          "type": "string",
          "description": "Directory containing E2E tests"
        },
        "timeout": {
          "type": "integer",
          "minimum": 1000,
          "default": 60000,
          "description": "Test timeout in milliseconds (default: 60000ms for E2E tests)"
        },
        "retries": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of retries on failure"
        },
        "workers": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of parallel workers"
        },
        "use": {
          "type": "object",
          "properties": {
            "screenshot": {
              "type": "string",
              "enum": ["on", "off", "only-on-failure"],
              "description": "Screenshot capture mode"
            },
            "video": {
              "type": "string",
              "enum": ["on", "off", "retain-on-failure", "on-first-retry"],
              "description": "Video recording mode"
            },
            "trace": {
              "type": "string",
              "enum": ["on", "off", "retain-on-failure", "on-first-retry"],
              "description": "Trace recording mode"
            }
          }
        }
      }
    },
    "webdriverio": {
      "type": "object",
      "description": "WebdriverIO configuration for webview testing",
      "properties": {
        "capabilities": {
          "type": "object",
          "properties": {
            "browserName": {
              "type": "string",
              "const": "vscode",
              "description": "Always 'vscode' for extension testing"
            },
            "browserVersion": {
              "type": "string",
              "enum": ["stable", "insiders"],
              "description": "VSCode version"
            }
          }
        },
        "services": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "WDIO services (e.g., ['vscode'])"
        },
        "specs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Test file patterns (e.g., ['./tests/e2e/webviews/**/*.test.ts'])"
        },
        "maxInstances": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum parallel test sessions"
        }
      }
    },
    "benchmark": {
      "type": "object",
      "description": "Performance benchmark configuration",
      "properties": {
        "time": {
          "type": "integer",
          "minimum": 1000,
          "default": 2000,
          "description": "Run duration in milliseconds (default: 2000ms per benchmark)"
        },
        "iterations": {
          "type": "integer",
          "minimum": 10,
          "description": "Minimum number of iterations"
        },
        "warmupTime": {
          "type": "integer",
          "minimum": 0,
          "description": "Warmup duration in milliseconds"
        },
        "warmupIterations": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of warmup iterations"
        },
        "targets": {
          "type": "object",
          "patternProperties": {
            "^[a-zA-Z0-9-_]+$": {
              "type": "number",
              "minimum": 0,
              "description": "Target performance in milliseconds (p50)"
            }
          },
          "description": "Performance targets for each benchmark (e.g., {'specLoading': 500})"
        }
      }
    },
    "telemetry": {
      "type": "object",
      "description": "Test telemetry and reporting configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable telemetry collection"
        },
        "outputFormat": {
          "type": "string",
          "enum": ["ctrf", "json", "junit", "html"],
          "description": "Primary output format"
        },
        "outputPath": {
          "type": "string",
          "description": "Directory for test results (e.g., 'test-results/')"
        },
        "collectMemoryMetrics": {
          "type": "boolean",
          "description": "Capture memory usage per test"
        },
        "collectExecutionTraces": {
          "type": "boolean",
          "description": "Capture step-by-step execution logs for failed tests"
        },
        "trackTrends": {
          "type": "boolean",
          "description": "Enable historical trend tracking"
        },
        "flakyTestThreshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "default": 10,
          "description": "Failure rate % to mark test as flaky (default: 10% over last 10 runs)"
        },
        "slowTestThreshold": {
          "type": "integer",
          "minimum": 100,
          "default": 1000,
          "description": "Duration in ms to mark test as slow (default: 1000ms)"
        },
        "baselineReportPath": {
          "type": "string",
          "description": "Path to baseline report for delta calculation"
        }
      }
    },
    "ci": {
      "type": "object",
      "description": "CI-specific configuration",
      "properties": {
        "parallel": {
          "type": "boolean",
          "description": "Run test suites in parallel"
        },
        "suites": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["unit", "integration", "e2e", "performance"]
          },
          "description": "Test suites to run in CI"
        },
        "artifactRetentionDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 400,
          "description": "Days to retain test artifacts (1-400)"
        },
        "failFast": {
          "type": "boolean",
          "description": "Stop on first test suite failure"
        },
        "uploadArtifacts": {
          "type": "boolean",
          "description": "Upload test results and coverage as artifacts"
        }
      }
    }
  }
}
