.vscode/**
.vscode-test/**
src/**
out/**
.gitignore
.yarnrc
webpack.config.js
**/tsconfig.json
**/.eslintrc.json
**/*.map
**/*.ts
# Keep the Language Server (copied during build)
!language-server/dist/**
!language-server/package.json
!language-server/node_modules/**
# Exclude Language Server source
language-server/src/**
# Exclude all node_modules by default
node_modules/**
# Persona-pack visuals + canonical command source-of-truth must ship in VSIX
# (T171 — feature 001-cli-innovations-visuals).
!resources/templates/visuals/**
!resources/templates/visuals/*.md
!resources/claude-commands/**
!resources/copilot-prompts/**
!resources/specify-commands/**
!resources/templates/**
