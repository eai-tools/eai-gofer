.vscode/**
.vscode-test/**
src/**
.gitignore
.yarnrc
webpack.config.js
**/tsconfig.json
**/.eslintrc.json
**/*.map
**/*.ts
# Keep the Language Server (copied during build)
!language-server/dist/**
!language-server/package.json
!language-server/node_modules/**
# Exclude Language Server source
language-server/src/**
# Exclude all node_modules by default
node_modules/**
# But keep node-pty-prebuilt-multiarch with all platform binaries
!node_modules/node-pty-prebuilt-multiarch/**
