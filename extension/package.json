{
  "name": "specgofer",
  "displayName": "SpecGofer (Enterprise AI) [PREVIEW]",
  "description": "Spec-driven development for AI. Exposes 6 MCP tools that let Claude Code and GitHub Copilot autonomously implement features from GitHub Spec Kit specifications.",
  "version": "2.0.6",
  "publisher": "EnterpriseAI",
  "icon": "icon.png",
  "author": {
    "name": "Enterprise AI Pty Ltd",
    "url": "https://enterpriseai.com.au"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/eai-tools/specgofer"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Testing",
    "Other"
  ],
  "keywords": [
    "spec-driven",
    "spec-kit",
    "github",
    "claude",
    "copilot",
    "ai",
    "testing",
    "playwright"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "specGofer.initialize",
        "title": "SpecGofer: Initialize Repository",
        "icon": "$(rocket)"
      },
      {
        "command": "specGofer.upgrade",
        "title": "SpecGofer: Upgrade to Spec Kit Format",
        "icon": "$(arrow-up)"
      },
      {
        "command": "specGofer.showProgress",
        "title": "SpecGofer: Show Progress Panel",
        "icon": "$(dashboard)"
      },
      {
        "command": "specGofer.refreshSpecs",
        "title": "SpecGofer: Refresh Specifications",
        "icon": "$(refresh)"
      },
      {
        "command": "specGofer.checkForUpdates",
        "title": "SpecGofer: Check for Updates",
        "icon": "$(cloud-download)"
      },
      {
        "command": "specGofer.updateNow",
        "title": "SpecGofer: Update Now",
        "icon": "$(desktop-download)"
      },
      {
        "command": "specGofer.refreshConstitution",
        "title": "SpecGofer: Refresh Constitution",
        "icon": "$(refresh)"
      },
      {
        "command": "specGofer.refreshMemory",
        "title": "SpecGofer: Refresh Memory",
        "icon": "$(refresh)"
      },
      {
        "command": "specGofer.showConstitution",
        "title": "SpecGofer: Show Constitution Panel",
        "icon": "$(law)"
      },
      {
        "command": "specGofer.updateTemplates",
        "title": "SpecGofer: Update Templates",
        "icon": "$(cloud-download)"
      },
      {
        "command": "specGofer.fixSpecPaths",
        "title": "SpecGofer: Fix Spec Path References (specs/ → .specify/specs/)",
        "icon": "$(wrench)"
      },
      {
        "command": "specGofer.openSpec",
        "title": "SpecGofer: Open Specification",
        "icon": "$(file-text)"
      },
      {
        "command": "specGofer.createSpec",
        "title": "SpecGofer: Create New Specification",
        "icon": "$(file-add)"
      },
      {
        "command": "specGofer.showSpecDetails",
        "title": "SpecGofer: Show Specification Details"
      },
      {
        "command": "specGofer.showSectionDetails",
        "title": "SpecGofer: Show Constitution Section Details"
      },
      {
        "command": "specGofer.showArticleDetails",
        "title": "SpecGofer: Show Constitution Article Details"
      },
      {
        "command": "specGofer.showMemoryDocument",
        "title": "SpecGofer: Show Memory Document"
      },
      {
        "command": "specGofer.showMemorySection",
        "title": "SpecGofer: Show Memory Section"
      },
      {
        "command": "specGofer.openWithPreview",
        "title": "Open with Preview"
      },
      {
        "command": "specGofer.openWithMarkSharp",
        "title": "Open with Mark Sharp"
      },
      {
        "command": "specGofer.openWithMarkdownEditor",
        "title": "Open with Markdown Editor"
      },
      {
        "command": "specGofer.openWithMarkdownWYSIWYG",
        "title": "Open with Markdown WYSIWYG"
      }
    ],
    "keybindings": [
      {
        "command": "specGofer.initialize",
        "key": "ctrl+shift+alt+i",
        "mac": "cmd+shift+alt+i",
        "when": "editorTextFocus || explorerResourceIsFolder"
      },
      {
        "command": "specGofer.showProgress",
        "key": "ctrl+shift+alt+p",
        "mac": "cmd+shift+alt+p"
      },
      {
        "command": "specGofer.refreshSpecs",
        "key": "ctrl+shift+alt+r",
        "mac": "cmd+shift+alt+r"
      },
      {
        "command": "specGofer.showConstitution",
        "key": "ctrl+shift+alt+c",
        "mac": "cmd+shift+alt+c"
      },
      {
        "command": "specGofer.createSpec",
        "key": "ctrl+shift+alt+n",
        "mac": "cmd+shift+alt+n",
        "when": "explorerResourceIsFolder"
      },
      {
        "command": "specGofer.checkForUpdates",
        "key": "ctrl+shift+alt+u",
        "mac": "cmd+shift+alt+u"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "spec-kit",
          "title": "SpecGofer - Enterprise AI",
          "icon": "$(notebook)"
        }
      ]
    },
    "views": {
      "spec-kit": [
        {
          "id": "specGoferProgress",
          "name": "Specifications",
          "icon": "$(notebook)",
          "contextualTitle": "Spec Kit"
        },
        {
          "id": "specGoferConstitution",
          "name": "Constitution",
          "icon": "$(law)",
          "contextualTitle": "Project Principles"
        },
        {
          "id": "specGoferMemory",
          "name": "Memory",
          "icon": "$(database)",
          "contextualTitle": "Project Memory"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "specGoferProgress",
        "contents": "No SpecGofer structure found in this workspace.\n[Initialize SpecGofer](command:specGofer.initialize)\nThis will create the .specify folder structure following GitHub Spec Kit standards."
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "specGofer.refreshSpecs",
          "when": "view == specGoferProgress",
          "group": "navigation@1"
        },
        {
          "command": "specGofer.updateNow",
          "when": "view == specGoferProgress",
          "group": "navigation@2"
        },
        {
          "command": "specGofer.refreshConstitution",
          "when": "view == specGoferConstitution",
          "group": "navigation"
        },
        {
          "command": "specGofer.refreshMemory",
          "when": "view == specGoferMemory",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "specGofer.openWithPreview",
          "when": "viewItem == spec || viewItem == constitution-article || viewItem == constitution-section || viewItem == memory-document || viewItem == memory-section",
          "group": "openwith@1"
        },
        {
          "command": "specGofer.openWithMarkSharp",
          "when": "viewItem == spec || viewItem == constitution-article || viewItem == constitution-section || viewItem == memory-document || viewItem == memory-section",
          "group": "openwith@2"
        },
        {
          "command": "specGofer.openWithMarkdownEditor",
          "when": "viewItem == spec || viewItem == constitution-article || viewItem == constitution-section || viewItem == memory-document || viewItem == memory-section",
          "group": "openwith@3"
        },
        {
          "command": "specGofer.openWithMarkdownWYSIWYG",
          "when": "viewItem == spec || viewItem == constitution-article || viewItem == constitution-section || viewItem == memory-document || viewItem == memory-section",
          "group": "openwith@4"
        }
      ],
      "explorer/context": [
        {
          "command": "specGofer.initialize",
          "when": "explorerResourceIsFolder && !specGoferInitialized",
          "group": "specgofer@1"
        },
        {
          "command": "specGofer.createSpec",
          "when": "explorerResourceIsFolder && specGoferInitialized",
          "group": "specgofer@2"
        }
      ],
      "commandPalette": [
        {
          "command": "specGofer.initialize",
          "when": "!specGoferInitialized"
        },
        {
          "command": "specGofer.showProgress",
          "when": "specGoferInitialized"
        },
        {
          "command": "specGofer.showConstitution",
          "when": "specGoferInitialized"
        },
        {
          "command": "specGofer.refreshSpecs",
          "when": "specGoferInitialized"
        },
        {
          "command": "specGofer.refreshConstitution",
          "when": "specGoferInitialized"
        },
        {
          "command": "specGofer.upgrade",
          "when": "specGoferInitialized"
        },
        {
          "command": "specGofer.updateTemplates",
          "when": "specGoferInitialized"
        },
        {
          "command": "specGofer.createSpec",
          "when": "specGoferInitialized"
        }
      ]
    },
    "configuration": {
      "title": "SpecGofer",
      "properties": {
        "specGofer.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API Key for Claude (get yours at https://console.anthropic.com/settings/keys)",
          "markdownDescription": "Your Anthropic API key for Claude. [Get one here](https://console.anthropic.com/settings/keys). This is stored securely in VSCode settings and never shared.",
          "order": 0
        },
        "specGofer.autoInitialize": {
          "type": "boolean",
          "default": false,
          "description": "Automatically offer to initialize SpecGofer when opening a repository without it"
        },
        "specGofer.preferredAI": {
          "type": "string",
          "enum": [
            "claude",
            "copilot",
            "ask"
          ],
          "default": "ask",
          "description": "Preferred AI tool when sending tasks (ask, claude, copilot)"
        },
        "specGofer.claudeTerminalName": {
          "type": "string",
          "default": "Claude",
          "description": "Name pattern to identify Claude Code terminals"
        },
        "specGofer.autoValidate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically validate specs against constitution when creating/updating"
        },
        "specGofer.showWelcome": {
          "type": "boolean",
          "default": true,
          "description": "Show welcome message and quick start when initializing"
        },
        "specGofer.markdownViewer": {
          "type": "string",
          "enum": [
            "preview",
            "mark-sharp",
            "markdown-editor",
            "markdown-wysiwyg"
          ],
          "enumDescriptions": [
            "VSCode's built-in Markdown Preview (read-only)",
            "Mark Sharp - Fast WYSIWYG editor with live preview (requires extension: JonathanYeung.mark-sharp)",
            "Markdown Editor - Feature-rich WYSIWYG editor (requires extension: zaaack.markdown-editor)",
            "Markdown WYSIWYG - Simple WYSIWYG editor (requires extension: adamerose.markdown-wysiwyg)"
          ],
          "default": "preview",
          "description": "Choose how to view markdown files when clicking tree view items",
          "markdownDescription": "Choose how to view markdown files when clicking tree view items.\n\n**Recommended WYSIWYG Extensions:**\n- [Mark Sharp](https://marketplace.visualstudio.com/items?itemName=JonathanYeung.mark-sharp) - Fast & modern\n- [Markdown Editor](https://marketplace.visualstudio.com/items?itemName=zaaack.markdown-editor) - Feature-rich\n- [Markdown WYSIWYG](https://marketplace.visualstudio.com/items?itemName=adamerose.markdown-wysiwyg) - Simple"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run prepare-language-server && npm run package",
    "prepare-language-server": "cd ../language-server && npm run build && cd ../extension && rm -rf language-server && cp -r ../language-server language-server && rm -rf language-server/src",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.56.0",
    "glob": "^11.0.3",
    "mocha": "^11.7.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "yaml": "^2.8.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.67.0",
    "@types/jszip": "^3.4.0",
    "chokidar": "^3.5.3",
    "jszip": "^3.10.1",
    "vscode-languageclient": "^9.0.1"
  }
}
