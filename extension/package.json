{
  "name": "specgofer",
  "displayName": "SpecGofer (Enterprise AI) [PREVIEW]",
  "description": "Spec-driven development for AI. Exposes 6 MCP tools that let Claude Code and GitHub Copilot autonomously implement features from GitHub Spec Kit specifications.",
  "version": "1.7.0",
  "publisher": "EnterpriseAI",
  "icon": "icon.png",
  "author": {
    "name": "Enterprise AI Pty Ltd",
    "url": "https://enterpriseai.com.au"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/eai-tools/specgofer"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Testing",
    "Other"
  ],
  "keywords": [
    "spec-driven",
    "spec-kit",
    "github",
    "claude",
    "copilot",
    "ai",
    "testing",
    "playwright"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "specKit.initialize",
        "title": "SpecGofer: Initialize Repository",
        "icon": "$(rocket)"
      },
      {
        "command": "specKit.upgrade",
        "title": "SpecGofer: Upgrade to Spec Kit Format",
        "icon": "$(arrow-up)"
      },
      {
        "command": "specKit.showProgress",
        "title": "SpecGofer: Show Progress Panel",
        "icon": "$(dashboard)"
      },
      {
        "command": "specKit.refreshSpecs",
        "title": "SpecGofer: Refresh Specifications",
        "icon": "$(refresh)"
      },
      {
        "command": "specKit.checkForUpdates",
        "title": "SpecGofer: Check for Updates",
        "icon": "$(cloud-download)"
      },
      {
        "command": "specKit.updateNow",
        "title": "SpecGofer: Update Now",
        "icon": "$(desktop-download)"
      },
      {
        "command": "specKit.refreshConstitution",
        "title": "SpecGofer: Refresh Constitution",
        "icon": "$(refresh)"
      },
      {
        "command": "specKit.showConstitution",
        "title": "SpecGofer: Show Constitution Panel",
        "icon": "$(law)"
      },
      {
        "command": "specKit.updateTemplates",
        "title": "SpecGofer: Update Templates",
        "icon": "$(cloud-download)"
      },
      {
        "command": "specKit.openSpec",
        "title": "SpecGofer: Open Specification",
        "icon": "$(file-text)"
      },
      {
        "command": "specKit.createSpec",
        "title": "SpecGofer: Create New Specification",
        "icon": "$(file-add)"
      }
    ],
    "keybindings": [
      {
        "command": "specKit.initialize",
        "key": "ctrl+shift+alt+i",
        "mac": "cmd+shift+alt+i",
        "when": "editorTextFocus || explorerResourceIsFolder"
      },
      {
        "command": "specKit.showProgress",
        "key": "ctrl+shift+alt+p",
        "mac": "cmd+shift+alt+p"
      },
      {
        "command": "specKit.refreshSpecs",
        "key": "ctrl+shift+alt+r",
        "mac": "cmd+shift+alt+r"
      },
      {
        "command": "specKit.showConstitution",
        "key": "ctrl+shift+alt+c",
        "mac": "cmd+shift+alt+c"
      },
      {
        "command": "specKit.createSpec",
        "key": "ctrl+shift+alt+n",
        "mac": "cmd+shift+alt+n",
        "when": "explorerResourceIsFolder"
      },
      {
        "command": "specKit.checkForUpdates",
        "key": "ctrl+shift+alt+u",
        "mac": "cmd+shift+alt+u"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "spec-kit",
          "title": "SpecGofer - Enterprise AI",
          "icon": "$(notebook)"
        }
      ]
    },
    "views": {
      "spec-kit": [
        {
          "id": "specKitProgress",
          "name": "Specifications",
          "icon": "$(notebook)",
          "contextualTitle": "Spec Kit"
        },
        {
          "id": "specKitConstitution",
          "name": "Constitution",
          "icon": "$(law)",
          "contextualTitle": "Project Principles"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "specKitProgress",
        "contents": "No SpecGofer structure found in this workspace.\n[Initialize SpecGofer](command:specKit.initialize)\nThis will create the .specify folder structure following GitHub Spec Kit standards."
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "specKit.refreshSpecs",
          "when": "view == specKitProgress",
          "group": "navigation@1"
        },
        {
          "command": "specKit.updateNow",
          "when": "view == specKitProgress",
          "group": "navigation@2"
        },
        {
          "command": "specKit.refreshConstitution",
          "when": "view == specKitConstitution",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "specKit.initialize",
          "when": "explorerResourceIsFolder && !specKitInitialized",
          "group": "specgofer@1"
        },
        {
          "command": "specKit.createSpec",
          "when": "explorerResourceIsFolder && specKitInitialized",
          "group": "specgofer@2"
        }
      ],
      "commandPalette": [
        {
          "command": "specKit.initialize",
          "when": "!specKitInitialized"
        },
        {
          "command": "specKit.showProgress",
          "when": "specKitInitialized"
        },
        {
          "command": "specKit.showConstitution",
          "when": "specKitInitialized"
        },
        {
          "command": "specKit.refreshSpecs",
          "when": "specKitInitialized"
        },
        {
          "command": "specKit.refreshConstitution",
          "when": "specKitInitialized"
        },
        {
          "command": "specKit.upgrade",
          "when": "specKitInitialized"
        },
        {
          "command": "specKit.updateTemplates",
          "when": "specKitInitialized"
        },
        {
          "command": "specKit.createSpec",
          "when": "specKitInitialized"
        }
      ]
    },
    "configuration": {
      "title": "SpecGofer - Enterprise AI",
      "properties": {
        "specKit.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API Key for Claude (get yours at https://console.anthropic.com/settings/keys)",
          "markdownDescription": "Your Anthropic API key for Claude. [Get one here](https://console.anthropic.com/settings/keys). This is stored securely in VSCode settings and never shared.",
          "order": 0
        },
        "specKit.autoInitialize": {
          "type": "boolean",
          "default": false,
          "description": "Automatically offer to initialize SpecGofer when opening a repository without it"
        },
        "specKit.preferredAI": {
          "type": "string",
          "enum": [
            "claude",
            "copilot",
            "ask"
          ],
          "default": "ask",
          "description": "Preferred AI tool when sending tasks (ask, claude, copilot)"
        },
        "specKit.claudeTerminalName": {
          "type": "string",
          "default": "Claude",
          "description": "Name pattern to identify Claude Code terminals"
        },
        "specKit.autoValidate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically validate specs against constitution when creating/updating"
        },
        "specKit.showWelcome": {
          "type": "boolean",
          "default": true,
          "description": "Show welcome message and quick start when initializing"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run prepare-language-server && npm run package",
    "prepare-language-server": "cd ../language-server && npm run build && cd ../extension && rm -rf language-server && cp -r ../language-server language-server && rm -rf language-server/src",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.56.0",
    "glob": "^11.0.3",
    "mocha": "^11.7.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "yaml": "^2.8.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.67.0",
    "@types/jszip": "^3.4.0",
    "chokidar": "^3.5.3",
    "jszip": "^3.10.1",
    "vscode-languageclient": "^9.0.1"
  }
}
