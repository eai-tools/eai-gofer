{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "artifact-plan.schema.json",
  "title": "Plan Artifact Frontmatter",
  "description": "Validates YAML frontmatter of plan.md files",
  "type": "object",
  "required": ["feature", "spec", "status", "created"],
  "properties": {
    "feature": {
      "type": "string",
      "description": "Feature name"
    },
    "spec": {
      "type": "string",
      "description": "Reference to spec file"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "ready", "approved"],
      "description": "Plan status"
    },
    "created": {
      "type": "string",
      "description": "Creation date (ISO format)"
    },
    "research": {
      "type": "string",
      "description": "Reference to research file"
    },
    "updated": {
      "type": "string",
      "description": "Last update date"
    }
  }
}
