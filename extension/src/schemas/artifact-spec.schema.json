{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "artifact-spec.schema.json",
  "title": "Spec Artifact Frontmatter",
  "description": "Validates YAML frontmatter of spec.md files",
  "type": "object",
  "required": ["id", "title", "status", "created"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique feature identifier"
    },
    "title": {
      "type": "string",
      "description": "Feature title"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "ready", "approved"],
      "description": "Specification status"
    },
    "created": {
      "type": "string",
      "description": "Creation date (ISO format)"
    },
    "updated": {
      "type": "string",
      "description": "Last update date"
    },
    "author": {
      "type": "string",
      "description": "Specification author"
    },
    "priority": {
      "type": "string",
      "description": "Feature priority"
    },
    "assignee": {
      "type": "string",
      "description": "Assigned implementer"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Feature dependencies"
    }
  }
}
