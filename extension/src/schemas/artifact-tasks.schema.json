{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "artifact-tasks.schema.json",
  "title": "Tasks Artifact Frontmatter",
  "description": "Validates YAML frontmatter of tasks.md files",
  "type": "object",
  "required": ["feature", "plan", "status", "created"],
  "properties": {
    "feature": {
      "type": "string",
      "description": "Feature name"
    },
    "plan": {
      "type": "string",
      "description": "Reference to plan file"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "approved", "ready"],
      "description": "Tasks status"
    },
    "created": {
      "type": "string",
      "description": "Creation date (ISO format)"
    },
    "updated": {
      "type": "string",
      "description": "Last update date"
    },
    "totalTasks": {
      "type": "number",
      "description": "Total number of tasks"
    },
    "completedTasks": {
      "type": "number",
      "description": "Number of completed tasks"
    },
    "approvedBy": {
      "type": "string",
      "description": "Who approved the tasks"
    },
    "approvedAt": {
      "type": "string",
      "description": "When tasks were approved"
    }
  }
}
