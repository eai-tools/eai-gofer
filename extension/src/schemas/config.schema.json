{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/eai-tools/eai-gofer/schemas/config.schema.json",
  "title": "Gofer Configuration Schema",
  "description": "JSON Schema for validating Gofer extension configuration",
  "type": "object",
  "properties": {
    "gofer": {
      "type": "object",
      "properties": {
        "context": {
          "type": "object",
          "properties": {
            "maxTokens": {
              "type": "integer",
              "description": "Maximum context window size (tokens)",
              "minimum": 1000,
              "maximum": 2000000,
              "default": 200000
            },
            "healthyThreshold": {
              "type": "integer",
              "description": "Healthy usage threshold (50% of max)",
              "minimum": 1000,
              "maximum": 2000000,
              "default": 100000
            },
            "warningThreshold": {
              "type": "integer",
              "description": "Warning usage threshold (70% of max)",
              "minimum": 1000,
              "maximum": 2000000,
              "default": 140000
            },
            "criticalThreshold": {
              "type": "integer",
              "description": "Critical usage threshold (90% of max)",
              "minimum": 1000,
              "maximum": 2000000,
              "default": 180000
            }
          }
        },
        "cache": {
          "type": "object",
          "properties": {
            "spec": {
              "type": "object",
              "properties": {
                "maxEntries": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 1000,
                  "default": 50
                },
                "ttlMs": {
                  "type": "integer",
                  "minimum": 1000,
                  "maximum": 3600000,
                  "default": 300000
                },
                "tokenBudget": {
                  "type": "integer",
                  "minimum": 1000,
                  "maximum": 200000,
                  "default": 50000
                }
              }
            },
            "memory": {
              "type": "object",
              "properties": {
                "maxEntries": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 1000,
                  "default": 100
                },
                "ttlMs": {
                  "type": "integer",
                  "minimum": 1000,
                  "maximum": 3600000,
                  "default": 600000
                },
                "tokenBudget": {
                  "type": "integer",
                  "minimum": 1000,
                  "maximum": 200000,
                  "default": 30000
                }
              }
            }
          }
        },
        "timeouts": {
          "type": "object",
          "properties": {
            "defaultMs": {
              "type": "integer",
              "description": "Default operation timeout",
              "minimum": 1000,
              "maximum": 600000,
              "default": 30000
            },
            "llmRequestMs": {
              "type": "integer",
              "description": "LLM API request timeout",
              "minimum": 5000,
              "maximum": 600000,
              "default": 120000
            },
            "fileOperationMs": {
              "type": "integer",
              "description": "File operation timeout",
              "minimum": 1000,
              "maximum": 60000,
              "default": 10000
            }
          }
        },
        "languageServer": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable Language Server Protocol",
              "default": true
            },
            "trace": {
              "type": "string",
              "description": "LSP trace level",
              "enum": ["off", "messages", "verbose"],
              "default": "off"
            }
          }
        },
        "autoUpdate": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable automatic update checking",
              "default": true
            },
            "checkIntervalHours": {
              "type": "integer",
              "description": "Hours between update checks",
              "minimum": 1,
              "maximum": 168,
              "default": 24
            }
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
