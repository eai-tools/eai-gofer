{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pipeline-state.schema.json",
  "title": "Pipeline State",
  "description": "Persistent state for a Gofer pipeline run",
  "type": "object",
  "required": [
    "runId",
    "featureId",
    "featureDir",
    "currentStage",
    "completedStages",
    "startedAt",
    "updatedAt",
    "status"
  ],
  "properties": {
    "runId": {
      "type": "string",
      "description": "UUID v4 identifying this pipeline run",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "featureId": {
      "type": "string",
      "description": "Feature identifier (e.g., 002-gofer-gap-remediation)"
    },
    "featureDir": {
      "type": "string",
      "description": "Path to the feature directory relative to repo root"
    },
    "currentStage": {
      "type": "string",
      "description": "Current pipeline stage",
      "enum": ["1_research", "2_specify", "3_plan", "4_tasks", "5_implement", "6_validate"]
    },
    "completedStages": {
      "type": "array",
      "description": "Stages that have been completed",
      "items": {
        "type": "string",
        "enum": ["1_research", "2_specify", "3_plan", "4_tasks", "5_implement", "6_validate"]
      }
    },
    "startedAt": {
      "type": "string",
      "description": "ISO-8601 timestamp of pipeline start",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "description": "ISO-8601 timestamp of last state update",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "description": "Overall pipeline status",
      "enum": ["initialized", "in_progress", "completed", "error"]
    },
    "runMetrics": {
      "type": "object",
      "description": "Optional metrics for the pipeline run",
      "properties": {
        "totalTokens": {
          "type": "number",
          "description": "Total tokens consumed"
        },
        "estimatedCostUsd": {
          "type": "number",
          "description": "Estimated cost in USD"
        },
        "compactionCount": {
          "type": "number",
          "description": "Number of context compaction events"
        },
        "stageTimings": {
          "type": "object",
          "description": "ISO 8601 duration per stage",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
